#include <stdio.h>

int main() {
	int num1;
	int num2;
	char operator;
	printf("+,-,* or /: ");
	scanf("%c", &operator);
	
	printf("number1: ");
	scanf("%d", &num1);
	printf("number2: ");
	scanf("%d", &num2);
	
	if (operator == '+') {
		printf("%d\n", num1 + num2);
	}
	else if (operator == '-') {
		printf("%d\n", num1 - num2);
	}
	else if (operator == '*') {
		printf("%d\n", num1 * num2);
	}
	else if (operator == '/') {
		printf("%d\n", num1 / num2);
	}
	else {
		printf("invaldid \n");
	}	
	return 0;
}
